# Mail ZIIYS API 配置
MAIL_ZIIYS_TOKEN=your_mail_ziiys_token_here
MAIL_ZIIYS_DOMAIN=ziiy.eu.cc

# 可选：自定义邮箱前缀
# 设置后可生成如 test@ziiy.eu.cc
MAIL_ZIIYS_LOCAL_PART=

# 可选：是否使用随机前缀
# 支持：true / false / 1 / 0 / yes / no / on / off
# 如果未设置，默认行为：
# - 未设置 MAIL_ZIIYS_LOCAL_PART 时，默认 true
# - 已设置 MAIL_ZIIYS_LOCAL_PART 时，默认 false
MAIL_ZIIYS_RANDOM=

# 可选：自定义子域名
# 设置后可生成如 user@mail.ziiy.eu.cc
MAIL_ZIIYS_SUBDOMAIN=

# 可选：是否使用随机子域名
# 仅在未设置 MAIL_ZIIYS_SUBDOMAIN 时生效
# 设置 true 后可生成如 ops@x8k2m.ziiy.eu.cc
MAIL_ZIIYS_RANDOM_SUBDOMAIN=

# 可选：调试输出
# 启用后会打印完整请求/响应调试信息
SIGNUP_WORKFLOW_DEBUG=false

# 可选：获取最新邮件脚本默认邮箱
MAIL_ZIIYS_MAILBOX_EMAIL=